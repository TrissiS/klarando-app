  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([displayId, createdAt])
  @@index([expiresAt])
  @@index([consumedAt])
  @@index([revokedAt])
}

model OrderDeskDeviceBinding {
  id             String   @id @default(uuid())
  deviceSerial   String   @unique
  tenantId       String
  displayId      String
  displayCode    String
  deviceAlias    String?
  deviceModel    String?
  devicePlatform String?
  appVersion     String?
