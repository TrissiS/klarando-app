generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  CHAINADMIN
  ADMIN
  STAFF
  DRIVER
}

enum PermissionKey {
  TENANTS_READ
  TENANTS_WRITE
  USERS_READ
  USERS_WRITE
  PRODUCTS_READ
  PRODUCTS_WRITE
  INVENTORY_READ
  INVENTORY_WRITE
  ORDERS_READ
  ORDERS_WRITE
  SETTINGS_READ
  SETTINGS_WRITE
  AUDIT_READ
}

enum StockMovementType {
  GOODS_RECEIPT
  WRITE_OFF
  INVENTORY_COUNT
}

enum ActionKind {
  DAILY
  WEEKLY
  ONE_TIME
}

enum ActionValueType {
  PERCENT
  FIXED_PRICE
}

enum StaffShiftStatus {
  PLANNED
  COMPLETED
  CANCELED
}

enum OrderDisplayRole {
  CASH
  KITCHEN
  PICKUP
}

enum IngredientCategory {
  FOOD
  PACKAGING
}

enum BeverageContainerType {
  NONE
  EINWEG
  MEHRWEG
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MOLLIE
  ADYEN
}

enum PaymentMethodType {
  CARD
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  KLARNA
  SOFORT
  SEPA_DEBIT
}

enum PaymentMethodStatus {
  ENABLED
  DISABLED
  DEPRECATED
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum FeeBearer {
  CUSTOMER
  TENANT
  PLATFORM
}

enum ProviderAccountStatus {
  PENDING
  ACTIVE
  RESTRICTED
  DISABLED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  WON
  LOST
  CLOSED
}

enum FeatureModuleKey {
  ORDERS
  PRODUCTS
  CATEGORIES
  INGREDIENTS
  ALLERGENS
  STOCK
  SUPPLIERS
  STAFF
  DRIVERS
  DISPLAYS
  DISPLAY_DESIGN
  ORDERDESK
  TERMINALS
  POS
  DELIVERY_ZONES
  RATINGS
  TIPS
  LOYALTY
  PAYMENT
  ANALYTICS
  CASH_CLOSING
  PLATFORM_BRANDING
}

enum BillingPlanType {
  REVENUE_SHARE
  MONTHLY_FIXED
  ORDER_PACKAGE
  HYBRID
  CUSTOM
}

enum BillingPeriodType {
  MONTHLY
  WEEKLY
}

enum BillingUsagePeriodStatus {
  OPEN
  CLOSED
  FINALIZED
}

enum BillingUsageCounterKey {
  ORDERS_TOTAL
  ORDERS_COUNTED
  ORDERS_CANCELED
  REVENUE_GROSS_CENTS
  REVENUE_COUNTED_CENTS
}

enum CommissionRuleType {
  PERCENT
  FIXED_PER_ORDER
  HYBRID
  THRESHOLD
}

enum BusinessTemplateType {
  DONER_KEBAP
  PIZZERIA
  BURGER_SMASHBURGER
  GRILL_IMBISS
  ASIAN
  CAFE_BAKERY
  BEVERAGE_DELIVERY
  KIOSK_SPATI
  RESTAURANT_GENERAL
  STEAKHOUSE_GRILLHOUSE
  SUSHI
  VEGAN_HEALTHY
  FOODTRUCK
  ICECREAM_DESSERT
  BAR_LOUNGE
}

enum ChainType {
  INDEPENDENT
  CHAIN
  FRANCHISE
}

enum EntityStatus {
  ACTIVE
  PAUSED
  ARCHIVED
  LOCKED
}

enum TemplateAllergenCode {
  A
  B
  C
  D
  E
  F
  G
  H
  I
  J
  K
  L
  M
  N
}

model BusinessTemplate {
  id          String                      @id @default(uuid())
  key         String                      @unique
  type        BusinessTemplateType
  name        String
  description String?
  isActive    Boolean                     @default(true)
  sortOrder   Int                         @default(0)
  categories  BusinessTemplateCategory[]
  ingredients BusinessTemplateIngredient[]
  products    BusinessTemplateProduct[]
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  @@index([type, isActive, sortOrder])
}

model BusinessTemplateCategory {
  id         String            @id @default(uuid())
  templateId String
  name       String
  sortOrder  Int               @default(0)
  template   BusinessTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  products   BusinessTemplateProduct[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([templateId, name])
  @@index([templateId, sortOrder])
}

model BusinessTemplateIngredient {
  id                   String                             @id @default(uuid())
  templateId           String
  name                 String
  category             IngredientCategory                 @default(FOOD)
  unit                 String
  recipeUnit           String?
  gramsPerPurchaseUnit Decimal?                           @db.Decimal(10, 3)
  purchasePrice        Decimal                            @default(0) @db.Decimal(10, 2)
  minimumStock         Decimal                            @default(0) @db.Decimal(12, 3)
  allergens            TemplateAllergenCode[]
  supplier             String?
  articleNumber        String?
  template             BusinessTemplate                   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  productRelations     BusinessTemplateProductIngredient[]
  createdAt            DateTime                           @default(now())
  updatedAt            DateTime                           @updatedAt

  @@unique([templateId, name])
  @@index([templateId, category])
}

model BusinessTemplateProduct {
  id               String                             @id @default(uuid())
  templateId       String
  categoryId       String?
  productNumber    String?
  name             String
  imageUrl         String?
  price            Decimal                            @db.Decimal(10, 2)
  vatRate          Decimal                            @default(19.00) @db.Decimal(5, 2)
  available        Boolean                            @default(true)
  template         BusinessTemplate                   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category         BusinessTemplateCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ingredientLinks  BusinessTemplateProductIngredient[]
  createdAt        DateTime                           @default(now())
  updatedAt        DateTime                           @updatedAt

  @@unique([templateId, name, categoryId])
  @@index([templateId, categoryId])
}

model BusinessTemplateProductIngredient {
  id                 String                     @id @default(uuid())
  templateProductId  String
  templateIngredientId String
  quantity           Decimal                    @db.Decimal(10, 3)
  product            BusinessTemplateProduct    @relation(fields: [templateProductId], references: [id], onDelete: Cascade)
  ingredient         BusinessTemplateIngredient @relation(fields: [templateIngredientId], references: [id], onDelete: Cascade)
  createdAt          DateTime                   @default(now())

  @@unique([templateProductId, templateIngredientId])
  @@index([templateIngredientId])
}

model Chain {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  type      ChainType    @default(INDEPENDENT)
  status    EntityStatus @default(ACTIVE)
  contactName String?
  contactEmail String?
  contactPhone String?
  payoutAccountHolder String?
  payoutBankName String?
  payoutIban String?
  payoutBic String?
  payoutEmail String?
  payoutReference String?
  tenants   Tenant[]
  customerProfiles CustomerProfile[]
  users     User[]
  auditLogs AuditLog[]
  featureModuleSettings ChainFeatureModuleSetting[]
  tenantFeatureModuleSettings TenantFeatureModuleSetting[]
  tenantBillingPlans TenantBillingPlan[]
  tenantBillingSettings TenantBillingSettings[]
  billingUsagePeriods BillingUsagePeriod[]
  commissionRules CommissionRule[]
  createdAt DateTime @default(now())
}

model Tenant {
  id         String    @id @default(uuid())
  chainId    String?
  name       String
  email      String?   @unique
  status     EntityStatus @default(ACTIVE)
  addressLine String?
  businessSettings Json?
  chain      Chain?    @relation(fields: [chainId], references: [id], onDelete: SetNull)

  products   Product[]
  categories Category[]
  customerProfiles CustomerProfile[]
  suppliers  Supplier[]
  stockMovements StockMovement[]
  actions    Action[]
  staffMembers StaffMember[]
  staffShifts StaffShift[]
  staffSetting StaffSetting?
  orders     Order[]
  orderTerminals OrderTerminal[]
  orderDisplays OrderDisplay[]
  chainAdminAccesses ChainAdminTenantAccess[]
  users      User[]
  auditLogs  AuditLog[]
  screenSetting ScreenSetting?
  screenProductSettings ScreenProductSetting[]
  screenDevices ScreenDevice[]
  productModifiers ProductModifier[]
  orderDeskDeviceBindings OrderDeskDeviceBinding[]
  orderDeskPairingSessions OrderDeskPairingSession[]
  paymentConfig TenantPaymentConfig?
  providerAccounts TenantProviderAccount[]
  paymentTransactions PaymentTransaction[]
  paymentWebhookEvents PaymentWebhookEvent[]
  paymentRefunds PaymentRefund[]
  paymentDisputes PaymentDispute[]
  tipTransactions TipTransaction[]
  paymentMethodOverrides TenantPaymentMethodOverride[]
  featureModuleSettings TenantFeatureModuleSetting[]
  tenantBillingPlan TenantBillingPlan?
  tenantBillingSettings TenantBillingSettings?
  billingUsagePeriods BillingUsagePeriod[]
  billingUsageCounters BillingUsageCounter[]
  commissionRules CommissionRule[]

  createdAt  DateTime  @default(now())

  @@index([chainId])
}

model CustomerProfile {
  id             String   @id @default(uuid())
  chainId        String?
  tenantId       String
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  street         String?
  zipCode        String?
  city           String?
  birthDate      DateTime? @db.Date
  loyaltyCode    String?
  marketingOptIn Boolean  @default(false)
  isActive       Boolean  @default(true)
  notes          String?
  createdByUserId String?
  chain          Chain?   @relation(fields: [chainId], references: [id], onDelete: SetNull)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([chainId, isActive, createdAt])
  @@index([tenantId, isActive, createdAt])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@unique([tenantId, loyaltyCode])
}

model AppCustomerAccount {
  id                  String   @id @default(uuid())
  email               String   @unique
  fullName            String
  passwordHash        String
  phone               String?
  street              String?
  zipCode             String?
  city                String?
  marketingOptIn      Boolean  @default(false)
  isActive            Boolean  @default(true)
  deletionRequestedAt DateTime?
  deletionRequestNote String?
  lastLoginAt         DateTime?
  orders              Order[]
  tipTransactions     TipTransaction[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isActive, createdAt])
  @@index([deletionRequestedAt])
}

model Category {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  sortOrder Int
  imageUrl  String?

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  createdAt DateTime  @default(now())
}

model Product {
  id            String              @id @default(uuid())
  tenantId      String
  categoryId    String?
  productNumber String?
  name          String
  imageUrl      String?
  ean           String?
  unitEans      Json?
  beverageContainerType BeverageContainerType @default(NONE)
  deposit       Decimal             @default(0) @db.Decimal(10, 2)
  articleInfo   String?
  foodBusinessOperator String?
  nutritionInfo String?
  price         Decimal             @db.Decimal(10, 2)
  vatRate       Decimal             @default(19.00) @db.Decimal(5, 2)
  available     Boolean             @default(true)

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category      Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ingredients   ProductIngredient[]
  actionLinks   ActionProduct[]
  orderItems    OrderItem[]
  screenSetting ScreenProductSetting?
  modifiers     ProductModifier[]

  createdAt     DateTime            @default(now())

  @@unique([tenantId, productNumber])
}

model ScreenSetting {
  id                    String   @id @default(uuid())
  tenantId              String   @unique
  title                 String   @default("Klarando Menu")
  subtitle              String?
  fontFamily            String   @default("Poppins, sans-serif")
  defaultOrientation    String   @default("LANDSCAPE")
  defaultResolutionWidth Int     @default(1920)
  defaultResolutionHeight Int    @default(1080)
  productFontSize       Int      @default(34)
  ingredientFontSize    Int      @default(12)
  categoryFontSize      Int      @default(12)
  priceFontSize         Int      @default(30)
  backgroundMode        String   @default("COLOR")
  backgroundValue       String?
  backgroundMediaUrl    String?
  overlayAnimation      String   @default("NONE")
  cardStyle             String   @default("SOFT")
  cardPadding           Int      @default(16)
  cardBackgroundOpacity Int      @default(35)
  cardBorderOpacity     Int      @default(20)
  productSortMode       String   @default("CUSTOM")
  defaultColumnCount    Int      @default(4)
  showCategoryHeaders   Boolean  @default(false)
  showCategoryOnCard    Boolean  @default(true)
  categoryUppercase     Boolean  @default(true)
  accentColor           String   @default("#ea580c")
  textColor             String   @default("#ffffff")
  productNameColor      String   @default("#ffffff")
  ingredientTextColor   String   @default("#e2e8f0")
  categoryTextColor     String   @default("#cbd5e1")
  priceTextColor        String   @default("#ffffff")
  showAllergens         Boolean  @default(true)
  allergenLegendEnabled Boolean  @default(true)
  allergenLegendPosition String  @default("BOTTOM_RIGHT")
  showPrices            Boolean  @default(true)
  pricePinnedLeft       Boolean  @default(false)
  priceDisplayMode      String   @default("EUR_SUFFIX")
  showUnavailable       Boolean  @default(false)
  showProductNumber     Boolean  @default(false)
  logoUrl               String?
  logoSize              Int      @default(72)
  offerWindowEnabled    Boolean  @default(false)
  offerWindowTitle      String?
  offerWindowText       String?
  offerWindowPosition   String   @default("RIGHT")
  offerWindowSize       String   @default("M")
  offerWindowWidthPx    Int      @default(380)
  offerWindowHeightPx   Int      @default(280)
  offerWindowXPercent   Int      @default(84)
  offerWindowYPercent   Int      @default(14)
  offerWindowReserveSpace Boolean @default(true)
  offerWindowBackgroundColor String @default("#f97316")
  offerWindowTextColor   String   @default("#ffffff")
  offerWindowOpacity     Int      @default(28)
  offerMediaUrls        Json?
  offerMediaRotateSec   Int      @default(12)
  tickerEnabled         Boolean  @default(false)
  tickerPosition        String   @default("BOTTOM")
  tickerShowClock       Boolean  @default(true)
  tickerDataSource      String   @default("CUSTOM")
  tickerCustomText      String?
  tickerApiUrl          String?
  tickerRefreshSec      Int      @default(180)
  tickerClockFontSize   Int      @default(12)
  tickerFontSize        Int      @default(14)
  tickerInsetPx         Int      @default(0)
  tickerOffsetPx        Int      @default(0)
  tickerBackgroundColor String   @default("#111827")
  tickerTextColor       String   @default("#ffffff")
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ScreenProductSetting {
  id               String   @id @default(uuid())
  tenantId         String
  productId        String   @unique
  displayCategory  String?
  sortOrder        Int      @default(0)
  showOnScreen     Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  badgeText        String?
  highlightColor   String?
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, showOnScreen, sortOrder])
  @@index([tenantId, displayCategory])
}

model ScreenDevice {
  id                          String    @id @default(uuid())
  tenantId                    String
  name                        String
  deviceCode                  String    @unique
  location                    String?
  isActive                    Boolean   @default(true)
  orientation                 String    @default("LANDSCAPE")
  resolutionWidth             Int       @default(1920)
  resolutionHeight            Int       @default(1080)
  refreshIntervalSec          Int       @default(30)
  showPricesOverride          Boolean?
  showAllergensOverride       Boolean?
  showUnavailableOverride     Boolean?
  showProductNumberOverride   Boolean?
  offerWindowEnabledOverride  Boolean?
  offerWindowPositionOverride String?
  offerWindowSizeOverride     String?
  offerMediaUrlsOverride      Json?
  offerMediaRotateSecOverride Int?
  cardStyleOverride           String?
  columnCountOverride         Int?
  selectedCategoryIds         String?
  selectedProductIds          String?
  backgroundMediaUrlOverride  String?
  accentColorOverride         String?
  textColorOverride           String?
  notes                       String?
  lastSeenAt                  DateTime?
  tenant                      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@index([tenantId, isActive])
  @@index([tenantId, name])
}

model Ingredient {
  id                 String              @id @default(uuid())
  tenantId           String
  name               String
  category           IngredientCategory  @default(FOOD)
  unit               String
  recipeUnit         String?
  gramsPerPurchaseUnit Decimal?         @db.Decimal(10, 3)
  purchasePrice      Decimal             @db.Decimal(10, 2)
  minimumStock       Decimal             @default(0) @db.Decimal(12, 3)
  consumptionFactorPercent Decimal       @default(0) @db.Decimal(6, 3)
  deposit            Decimal             @default(0) @db.Decimal(10, 2)
  ean                String?
  unitEans           Json?
  allergens          String?
  supplier           String?
  articleNumber      String?
  productIngredients ProductIngredient[]
  stockMovements     StockMovement[]
  modifierOptions    ProductModifier[]

  createdAt          DateTime            @default(now())
}

model Supplier {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  contactName String?
  phone       String?
  email       String?
  notes       String?
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ProductIngredient {
  id           String      @id @default(uuid())
  productId    String
  ingredientId String
  quantity     Decimal     @db.Decimal(10, 2)

  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  createdAt    DateTime    @default(now())
}

model Order {
  id                   String        @id @default(uuid())
  tenantId             String
  terminalId           String?
  appCustomerAccountId String?
  customerName         String?
  customerPhone        String?
  customerAddress      String?
  customerZipCode      String?
  customerCity         String?
  serviceType          String?
  subtotal             Decimal       @default(0) @db.Decimal(10, 2)
  deliveryFee          Decimal       @default(0) @db.Decimal(10, 2)
  cashDisplayId        String?
  kitchenDisplayId     String?
  pickupDisplayId      String?
  pickupNumber         Int?
  pickupAnnouncedAt    DateTime?
  pickupAnnounceUntil  DateTime?
  acceptedAt           DateTime?
  estimatedReadyAt     DateTime?
  estimatedMinutes     Int?
  total                Decimal       @db.Decimal(10, 2)
  status               String
  sourceChannel        String        @default("POS")
  paymentStatus        String        @default("UNPAID")
  paymentMethod        String?
  paidAt               DateTime?
  assignedDriverId     String?
  assignedDriverName   String?
  driverAssignedAt     DateTime?
  driverDepartedAt     DateTime?
  forwardedToKitchenAt DateTime?
  inventoryDeductedAt  DateTime?
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminal             OrderTerminal? @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  appCustomerAccount   AppCustomerAccount? @relation(fields: [appCustomerAccountId], references: [id], onDelete: SetNull)
  assignedDriver       User? @relation("OrderAssignedDriver", fields: [assignedDriverId], references: [id], onDelete: SetNull)
  cashDisplay          OrderDisplay? @relation("CashDisplayOrders", fields: [cashDisplayId], references: [id], onDelete: SetNull)
  kitchenDisplay       OrderDisplay? @relation("KitchenDisplayOrders", fields: [kitchenDisplayId], references: [id], onDelete: SetNull)
  pickupDisplay        OrderDisplay? @relation("PickupDisplayOrders", fields: [pickupDisplayId], references: [id], onDelete: SetNull)
  items                OrderItem[]
  paymentTransactions  PaymentTransaction[]
  paymentRefunds       PaymentRefund[]
  paymentDisputes      PaymentDispute[]
  tipTransactions      TipTransaction[]
  createdAt            DateTime      @default(now())

  @@index([tenantId, status, createdAt])
  @@index([tenantId, sourceChannel, createdAt])
  @@index([tenantId, inventoryDeductedAt])
  @@index([terminalId, createdAt])
  @@index([cashDisplayId, status, createdAt])
  @@index([kitchenDisplayId, status, createdAt])
  @@index([pickupDisplayId, status, createdAt])
  @@index([appCustomerAccountId, createdAt])
  @@index([assignedDriverId, status, createdAt])
  @@index([acceptedAt, estimatedReadyAt])
  @@index([tenantId, pickupNumber, createdAt])
  @@index([tenantId, pickupAnnounceUntil])
}

model TenantPaymentConfig {
  id                               String          @id @default(uuid())
  tenantId                         String          @unique
  defaultProvider                  PaymentProvider @default(STRIPE)
  commissionPercent                Decimal         @default(0) @db.Decimal(6, 3)
  fixedFeeCents                    Int             @default(0)
  paymentFeeBearer                 FeeBearer       @default(TENANT)
  allowMethodSurchargeToCustomer   Boolean         @default(false)
  methodSurchargeJson              Json?
  currency                         String          @default("EUR")
  isActive                         Boolean         @default(true)
  tenant                           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt                        DateTime        @default(now())
  updatedAt                        DateTime        @updatedAt

  @@index([defaultProvider, isActive])
}

model PlatformPaymentMethod {
  id                String              @id @default(uuid())
  provider          PaymentProvider
  methodType        PaymentMethodType
  status            PaymentMethodStatus @default(ENABLED)
  enabled           Boolean             @default(true)
  displayName       String
  checkoutSortOrder Int                 @default(100)
  countriesJson     Json?
  currenciesJson    Json?
  metadata          Json?
  tenantOverrides   TenantPaymentMethodOverride[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([provider, methodType])
  @@index([enabled, status, checkoutSortOrder])
}

model TenantPaymentMethodOverride {
  id                String                @id @default(uuid())
  tenantId          String
  paymentMethodId   String
  enabled           Boolean?
  feeBearer         FeeBearer?
  surchargePercent  Decimal?              @db.Decimal(6, 3)
  surchargeFixed    Int?
  reason            String?
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentMethod     PlatformPaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([tenantId, paymentMethodId])
  @@index([tenantId])
}

model ChainFeatureModuleSetting {
  id                  String           @id @default(uuid())
  chainId             String
  featureKey          FeatureModuleKey
  enabled             Boolean          @default(true)
  enabledBySuperadmin Boolean          @default(true)
  updatedBy           String?
  chain               Chain            @relation(fields: [chainId], references: [id], onDelete: Cascade)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@unique([chainId, featureKey])
  @@index([chainId])
}

model TenantFeatureModuleSetting {
  id                  String           @id @default(uuid())
  tenantId            String
  chainId             String?
  featureKey          FeatureModuleKey
  enabled             Boolean          @default(true)
  enabledBySuperadmin Boolean          @default(true)
  updatedBy           String?
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chain               Chain?           @relation(fields: [chainId], references: [id], onDelete: SetNull)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@unique([tenantId, featureKey])
  @@index([tenantId])
  @@index([chainId])
}

model BillingPlanTemplate {
  id                                     String             @id @default(uuid())
  key                                    String             @unique
  name                                   String
  description                            String?
  planType                               BillingPlanType
  monthlyFeeCents                        Int                @default(0)
  includedOrders                         Int                @default(0)
  commissionPercent                      Decimal            @default(0) @db.Decimal(6, 3)
  commissionAfterIncludedOrdersPercent   Decimal?           @db.Decimal(6, 3)
  fixedFeePerOrderCents                  Int                @default(0)
  billingPeriod                          BillingPeriodType  @default(MONTHLY)
  isActive                               Boolean            @default(true)
  metadata                               Json?
  createdAt                              DateTime           @default(now())
  updatedAt                              DateTime           @updatedAt

  @@index([isActive, planType])
}

model TenantBillingPlan {
  id                                   String             @id @default(uuid())
  tenantId                             String             @unique
  chainId                              String?
  planType                             BillingPlanType
  monthlyFeeCents                      Int                @default(0)
  includedOrders                       Int                @default(0)
  commissionPercent                    Decimal            @default(0) @db.Decimal(6, 3)
  commissionAfterIncludedOrdersPercent Decimal?           @db.Decimal(6, 3)
  fixedFeePerOrderCents                Int                @default(0)
  billingPeriod                        BillingPeriodType  @default(MONTHLY)
  activeFrom                           DateTime           @default(now())
  activeUntil                          DateTime?
  isActive                             Boolean            @default(true)
  notes                                String?
  updatedBy                            String?
  tenant                               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chain                                Chain?             @relation(fields: [chainId], references: [id], onDelete: SetNull)
  createdAt                            DateTime           @default(now())
  updatedAt                            DateTime           @updatedAt

  @@index([chainId])
  @@index([isActive, planType, activeFrom])
}

model TenantBillingSettings {
  id                         String   @id @default(uuid())
  tenantId                   String   @unique
  chainId                    String?
  paymentFeeBearer           FeeBearer @default(TENANT)
  countOnlyPaidOrders        Boolean  @default(true)
  countOnlyCompletedOrders   Boolean  @default(true)
  excludeCanceledOrders      Boolean  @default(true)
  revenueMode                String   @default("GROSS")
  currency                   String   @default("EUR")
  timezone                   String   @default("Europe/Berlin")
  notes                      String?
  isActive                   Boolean  @default(true)
  updatedBy                  String?
  tenant                     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chain                      Chain?   @relation(fields: [chainId], references: [id], onDelete: SetNull)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([chainId])
  @@index([isActive])
}

model BillingUsagePeriod {
  id                 String                   @id @default(uuid())
  tenantId           String
  chainId            String?
  periodStart        DateTime
  periodEnd          DateTime
  status             BillingUsagePeriodStatus @default(OPEN)
  ordersTotal        Int                      @default(0)
  ordersCounted      Int                      @default(0)
  ordersCanceled     Int                      @default(0)
  revenueGrossCents  Int                      @default(0)
  revenueCountedCents Int                     @default(0)
  snapshotAt         DateTime?
  metadata           Json?
  tenant             Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chain              Chain?                   @relation(fields: [chainId], references: [id], onDelete: SetNull)
  counters           BillingUsageCounter[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId, status, periodStart])
  @@index([chainId, status, periodStart])
}

model BillingUsageCounter {
  id            String                @id @default(uuid())
  usagePeriodId String
  tenantId      String
  counterKey    BillingUsageCounterKey
  valueInt      Int                   @default(0)
  valueDecimal  Decimal?              @db.Decimal(16, 4)
  metadata      Json?
