  display        OrderDisplay @relation(fields: [displayId], references: [id], onDelete: Cascade)
  boundByUser    User?    @relation("OrderDeskBindingBoundBy", fields: [boundByUserId], references: [id], onDelete: SetNull)
  resetByUser    User?    @relation("OrderDeskBindingResetBy", fields: [resetByUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

