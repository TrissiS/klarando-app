model StockMovement {
  id               String            @id @default(uuid())
  tenantId         String
  ingredientId     String
  type             StockMovementType
  quantityDelta    Decimal           @db.Decimal(12, 3)
  resultingQuantity Decimal          @db.Decimal(12, 3)
  countedQuantity  Decimal?          @db.Decimal(12, 3)
  unitCost         Decimal?          @db.Decimal(10, 2)
  reference        String?
  note             String?
  createdByUserId  String?
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ingredient       Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  createdByUser    User?             @relation("StockMovementActor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime          @default(now())

  @@index([tenantId, ingredientId, createdAt])
  @@index([tenantId, createdAt])
}

model Action {
  id             String          @id @default(uuid())
  tenantId       String
  name           String
  description    String?
  imageUrl       String?
  displayAsMenu  Boolean         @default(false)
  hidePriceOnScreen Boolean      @default(false)
  kind           ActionKind
  valueType      ActionValueType
  value          Decimal         @db.Decimal(10, 2)
  isActive       Boolean         @default(true)
  startAt        DateTime?
  endAt          DateTime?
  weeklyDays     String?
  dailyStartTime String?
  dailyEndTime   String?
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products       ActionProduct[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([tenantId, isActive, kind])
  @@index([tenantId, createdAt])
}

model ActionProduct {
  id        String   @id @default(uuid())
  actionId  String
  productId String
  action    Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([actionId, productId])
  @@index([productId])
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  name            String
  passwordHash    String
  role            UserRole
  isActive        Boolean          @default(true)
  chainId         String?
  tenantId        String?
  chain           Chain?           @relation(fields: [chainId], references: [id], onDelete: SetNull)
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userPermissions UserPermission[]
  chainAdminTenantAccesses ChainAdminTenantAccess[] @relation("ChainAdminAccessUser")
  auditLogs       AuditLog[]       @relation("AuditActor")
  stockMovements  StockMovement[]  @relation("StockMovementActor")
  assignedOrders  Order[]          @relation("OrderAssignedDriver")
  createdOrderDeskPairingSessions OrderDeskPairingSession[] @relation("OrderDeskPairingSessionCreator")
  orderDeskDeviceBindingsAsBinder OrderDeskDeviceBinding[] @relation("OrderDeskBindingBoundBy")
  orderDeskDeviceBindingsAsResetter OrderDeskDeviceBinding[] @relation("OrderDeskBindingResetBy")
  staffMemberProfile StaffMember?  @relation("StaffMemberUser")
  createdStaffShifts StaffShift[]  @relation("StaffShiftActor")
  passwordResetTokens PasswordResetToken[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([role])
  @@index([chainId])
  @@index([tenantId])
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  requestedIp String?
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt, usedAt])
}

model ChainAdminTenantAccess {
  id                    String   @id @default(uuid())
  chainAdminUserId      String
  tenantId              String
  superadminGranted     Boolean  @default(false)
  canViewRevenue        Boolean  @default(true)
  canManageAppOrders    Boolean  @default(true)
  canManageDelivery     Boolean  @default(true)
  canManagePickup       Boolean  @default(true)
  canViewPurchasing     Boolean  @default(true)
  canViewStaffPlanning  Boolean  @default(true)
  canOverrideSettings   Boolean  @default(false)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  chainAdminUser User   @relation("ChainAdminAccessUser", fields: [chainAdminUserId], references: [id], onDelete: Cascade)
  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([chainAdminUserId, tenantId])
  @@index([tenantId])
  @@index([chainAdminUserId, superadminGranted])
}

model StaffMember {
  id                String      @id @default(uuid())
  tenantId          String
  userId            String?     @unique
  name              String
  position          String?
  phone             String?
  email             String?
  hourlyRate        Decimal?    @db.Decimal(10, 2)
  weeklyTargetHours Decimal?    @db.Decimal(6, 2)
  isActive          Boolean     @default(true)
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User?       @relation("StaffMemberUser", fields: [userId], references: [id], onDelete: SetNull)
  shifts            StaffShift[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([tenantId, isActive])
  @@index([tenantId, name])
}

model StaffShift {
  id              String          @id @default(uuid())
  tenantId        String
  staffMemberId   String
  shiftDate       DateTime        @db.Date
  startTime       String
  endTime         String
  breakMinutes    Int             @default(0)
  status          StaffShiftStatus @default(PLANNED)
  note            String?
  createdByUserId String?
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffMember     StaffMember     @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  createdByUser   User?           @relation("StaffShiftActor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId, shiftDate])
  @@index([staffMemberId, shiftDate])
}

model StaffSetting {
  id                  String    @id @default(uuid())
  tenantId            String    @unique
  planningDays        Int       @default(14)
  defaultShiftStart   String    @default("10:00")
  defaultShiftEnd     String    @default("18:00")
  defaultBreakMinutes Int       @default(30)
  overtimeThresholdHours Decimal? @db.Decimal(6, 2)
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model RolePermission {
  id         String        @id @default(uuid())
  role       UserRole
  permission PermissionKey
  createdAt  DateTime      @default(now())

  @@unique([role, permission])
  @@index([role])
}

model UserPermission {
  id         String        @id @default(uuid())
  userId     String
  permission PermissionKey
  allowed    Boolean       @default(true)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())

  @@unique([userId, permission])
  @@index([userId])
}

model AuditLog {
  id         String    @id @default(uuid())
  actorUserId String?
  actorEmail String?
  actorRole  UserRole?
  chainId    String?
  tenantId   String?
  module     String
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime  @default(now())
  actorUser  User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  chain      Chain?    @relation(fields: [chainId], references: [id], onDelete: SetNull)
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([chainId])
  @@index([tenantId])
  @@index([module, createdAt])
}
