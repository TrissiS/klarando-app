  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([usagePeriodId, counterKey])
  @@index([tenantId, counterKey])
}

model CommissionRule {
  id                    String              @id @default(uuid())
  tenantId              String
  chainId               String?
  name                  String
  ruleType              CommissionRuleType
  isActive              Boolean             @default(true)
  priority              Int                 @default(100)
  conditionsJson        Json?
  commissionPercent     Decimal?            @db.Decimal(6, 3)
  fixedFeePerOrderCents Int?
  appliesAfterOrders    Int?
  activeFrom            DateTime?
  activeUntil           DateTime?
  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chain                 Chain?              @relation(fields: [chainId], references: [id], onDelete: SetNull)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([tenantId, isActive, priority])
  @@index([chainId, isActive, priority])
}

model TenantProviderAccount {
  id                      String                @id @default(uuid())
  tenantId                String
  provider                PaymentProvider
  providerAccountId       String
  status                  ProviderAccountStatus @default(PENDING)
  onboardingCompletedAt   DateTime?
  chargesEnabled          Boolean               @default(false)
  payoutsEnabled          Boolean               @default(false)
  capabilitiesJson        Json?
  detailsSubmittedAt      DateTime?
  disabledReason          String?
  tenant                  Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@unique([provider, providerAccountId])
  @@unique([tenantId, provider])
  @@index([tenantId, status])
}

model PaymentTransaction {
  id                      String          @id @default(uuid())
  tenantId                String
  orderId                 String?
  provider                PaymentProvider
  status                  PaymentStatus   @default(PENDING)
  providerPaymentId       String?
  providerClientSecretRef String?
  idempotencyKey          String?
  currency                String          @default("EUR")
  amountCents             Int
  feeAmountCents          Int             @default(0)
  platformFeeCents        Int             @default(0)
  providerFeeCents        Int             @default(0)
  feeBearer               FeeBearer       @default(TENANT)
  metadata                Json?
  processedAt             DateTime?
  failureCode             String?
  failureMessage          String?
  tenant                  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order                   Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  refunds                 PaymentRefund[]
  disputes                PaymentDispute[]
  tipTransactions         TipTransaction[]
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@unique([provider, providerPaymentId])
  @@unique([provider, idempotencyKey])
  @@index([tenantId, status, createdAt])
  @@index([orderId, createdAt])
  @@index([provider, status, createdAt])
}

model PaymentWebhookEvent {
  id              String          @id @default(uuid())
  tenantId        String
  provider        PaymentProvider
  providerEventId String
  eventType       String
  payload         Json
  processed       Boolean         @default(false)
  processedAt     DateTime?
  processingError String?
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())

  @@unique([provider, providerEventId])
  @@index([tenantId, createdAt])
  @@index([processed, createdAt])
}

model PaymentRefund {
  id                  String             @id @default(uuid())
  tenantId            String
  paymentTransactionId String
  orderId             String?
  provider            PaymentProvider
  status              RefundStatus       @default(PENDING)
  providerRefundId    String?
  amountCents         Int
  reason              String?
  metadata            Json?
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentTransaction  PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)
  order               Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([provider, providerRefundId])
  @@index([tenantId, status, createdAt])
  @@index([paymentTransactionId, createdAt])
}

model PaymentDispute {
  id                  String             @id @default(uuid())
  tenantId            String
  paymentTransactionId String
  orderId             String?
  provider            PaymentProvider
  status              DisputeStatus      @default(OPEN)
  providerDisputeId   String?
  amountCents         Int?
  reason              String?
  evidenceDueAt       DateTime?
  resolvedAt          DateTime?
  metadata            Json?
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentTransaction  PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)
  order               Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([provider, providerDisputeId])
  @@index([tenantId, status, createdAt])
  @@index([paymentTransactionId, createdAt])
}

model TipTransaction {
  id                  String             @id @default(uuid())
  tenantId            String
  orderId             String
  customerId          String
  paymentTransactionId String?
  provider            PaymentProvider?
  status              PaymentStatus      @default(PENDING)
  providerPaymentId   String?
  currency            String             @default("EUR")
  amountCents         Int
  metadata            Json?
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order               Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer            AppCustomerAccount @relation(fields: [customerId], references: [id], onDelete: Cascade)
  paymentTransaction  PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([provider, providerPaymentId])
  @@index([tenantId, status, createdAt])
  @@index([orderId, createdAt])
  @@index([customerId, createdAt])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  unitBasePrice Decimal? @db.Decimal(10, 2)
  unitModifierDelta Decimal? @db.Decimal(10, 2)
  modifierSnapshot Json?
  productionStatus String @default("OPEN")
  productionDoneAt DateTime?

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model OrderTerminal {
  id                 String   @id @default(uuid())
  tenantId           String
  name               String
  terminalCode       String   @unique
  location           String?
  customerLogoUrl    String?
  customerAccentColor String @default("#ea580c")
  customerBgFromColor String @default("#ffedd5")
  customerBgToColor  String  @default("#f8fafc")
  customerCardColor  String  @default("#ffffff")
  autoScaleLayout    Boolean @default(true)
  isActive           Boolean  @default(true)
  allowCashPayment   Boolean  @default(true)
  allowCardPayment   Boolean  @default(true)
  autoForwardToKitchen Boolean @default(true)
  cashDisplayId      String?
  kitchenDisplayId   String?
  pickupDisplayId    String?
  notes              String?
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashDisplay        OrderDisplay? @relation("CashDisplayTerminals", fields: [cashDisplayId], references: [id], onDelete: SetNull)
  kitchenDisplay     OrderDisplay? @relation("KitchenDisplayTerminals", fields: [kitchenDisplayId], references: [id], onDelete: SetNull)
  pickupDisplay      OrderDisplay? @relation("PickupDisplayTerminals", fields: [pickupDisplayId], references: [id], onDelete: SetNull)
  orders             Order[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId, isActive, name])
  @@index([cashDisplayId])
  @@index([kitchenDisplayId])
  @@index([pickupDisplayId])
}

model OrderDisplay {
  id               String   @id @default(uuid())
  tenantId         String
  name             String
  displayCode      String   @unique
  displayRole      OrderDisplayRole @default(KITCHEN)
  location         String?
  isActive         Boolean  @default(true)
  refreshIntervalSec Int    @default(10)
  sortMode         String   @default("PRIORITY_OLDEST")
  doneAutoHideSec  Int      @default(0)
  sourceTerminalIds String?
  announceOnMenuScreens Boolean @default(true)
  menuAnnouncementDurationSec Int @default(45)
  displayBackgroundColor String @default("#020617")
  orderCardBackgroundColor String @default("#0f172a")
  statusColorPendingPayment String @default("#ef4444")
  statusColorOpen  String   @default("#f97316")
  statusColorPreparing String @default("#3b82f6")
  statusColorDone  String   @default("#16a34a")
  showOrderAge     Boolean  @default(true)
  showTerminalInfo Boolean  @default(true)
  showPaymentInfo  Boolean  @default(true)
  showTotal        Boolean  @default(true)
  showItems        Boolean  @default(true)
  showStatusBadge  Boolean  @default(true)
  showPickupNumber Boolean  @default(true)
  showOrderNumber  Boolean  @default(true)
  autoScaleLayout  Boolean  @default(true)
  pickupShowOnlyNumber Boolean @default(false)
  pickupShowOpen   Boolean  @default(true)
  pickupShowPreparing Boolean @default(true)
  pickupShowDone   Boolean  @default(true)
  statusAnimationMode String @default("NONE")
  statusAnimationDurationMs Int @default(2200)
  orderAgeFontSize Int @default(22)
  orderAgeAlertThresholdSec Int @default(900)
  orderAgeAlertAnimationMode String @default("BLINK")
  backgroundMediaMode String @default("NONE")
  backgroundMediaUrl String?
  notes            String?
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashTerminals    OrderTerminal[] @relation("CashDisplayTerminals")
  kitchenTerminals OrderTerminal[] @relation("KitchenDisplayTerminals")
  pickupTerminals  OrderTerminal[] @relation("PickupDisplayTerminals")
  cashOrders       Order[] @relation("CashDisplayOrders")
  kitchenOrders    Order[] @relation("KitchenDisplayOrders")
  pickupOrders     Order[] @relation("PickupDisplayOrders")
  orderDeskDeviceBindings OrderDeskDeviceBinding[]
  orderDeskPairingSessions OrderDeskPairingSession[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, isActive, name])
  @@index([tenantId, displayRole, isActive])
}

model OrderDeskPairingSession {
  id              String   @id
  tenantId        String
  displayId       String
  displayCode     String
  deviceAlias     String?
  createdByUserId String?
  expiresAt       DateTime
  consumedAt      DateTime?
