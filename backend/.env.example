# Runtime
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public

# Auth / Tokens (mindestens JWT_SECRET in Produktion setzen)
JWT_SECRET=replace-with-long-random-secret
AUTH_SECRET=replace-with-long-random-secret
APP_AUTH_SECRET=replace-with-long-random-secret
AUTH_TOKEN_TTL_SECONDS=43200
APP_AUTH_TOKEN_TTL_SECONDS=2592000
AUTH_ENFORCE=true
GOOGLE_OAUTH_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Password Hashing
PASSWORD_BCRYPT_COST=12
# Nur fuer Legacy-SHA-Verifikation waehrend Migration noetig
PASSWORD_SALT=replace-legacy-salt-if-needed

# CORS (Komma-separiert; kein * in Produktion)
CORS_ORIGINS=https://klarando.com,https://www.klarando.com,https://app.klarando.com,https://admin.klarando.com,https://orderdesk.klarando.com,https://driver.klarando.com

# Produktions-Schutz fuer DB-Provisionierung (CREATE DATABASE / CREATE USER / GRANT)
# Standard: deaktiviert lassen, nur fuer kontrollierte Provisionierung aktivieren
ALLOW_PRODUCTION_DB_PROVISIONING=false

# Produktions-Schutz fuer gefaehrliche DB-Aktionen (DROP/DELETE/RESET)
# Standard: deaktiviert lassen, nur fuer Wartungsfenster aktivieren
ALLOW_PRODUCTION_DB_DESTRUCTIVE_ACTIONS=false

# Passwort-Reset / Mail
PUBLIC_APP_URL=https://klarando.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Klarando <noreply@klarando.com>"
SMTP_SECURE=false

# PayPal Plattform-Checkout
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLATFORM_MERCHANT_ID=
PAYPAL_PARTNER_ATTRIBUTION_ID=

# Stripe Connect Marketplace
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_REFRESH_URL=
STRIPE_CONNECT_RETURN_URL=
STRIPE_PLATFORM_FEE_PERCENT=12
STRIPE_PLATFORM_FEE_FIXED_CENTS=0
STRIPE_CHECKOUT_BASE_URL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
