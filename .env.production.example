# -------------------------------------------------
# Docker Compose / Infrastruktur
# -------------------------------------------------
COMPOSE_PROJECT_NAME=klarando

POSTGRES_DB=klarando_prod
POSTGRES_USER=klarando
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# Interner Compose-Host fuer Backend -> Postgres
DATABASE_URL=postgresql://klarando:replace-with-strong-postgres-password@postgres:5432/klarando_prod?schema=public

# -------------------------------------------------
# Backend Runtime
# -------------------------------------------------
NODE_ENV=production
PORT=4000

JWT_SECRET=replace-with-long-random-secret
AUTH_SECRET=replace-with-long-random-secret
APP_AUTH_SECRET=replace-with-long-random-secret
GOOGLE_OAUTH_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

AUTH_TOKEN_TTL_SECONDS=43200
APP_AUTH_TOKEN_TTL_SECONDS=2592000
AUTH_ENFORCE=true

PASSWORD_BCRYPT_COST=12
PASSWORD_SALT=replace-legacy-salt-if-needed
PUBLIC_APP_URL=https://klarando.com

# SMTP für Transaktionsmails
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=noreply@klarando.com
SMTP_PASS=
SMTP_FROM="Klarando <noreply@klarando.com>"
SMTP_SECURE=false

# PayPal Plattform-Checkout
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLATFORM_MERCHANT_ID=
PAYPAL_PARTNER_ATTRIBUTION_ID=

# Stripe Connect Marketplace
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_REFRESH_URL=https://klarando.com/admin/payments/connect/refresh
STRIPE_CONNECT_RETURN_URL=https://klarando.com/admin/payments/connect/return
STRIPE_PLATFORM_FEE_PERCENT=12
STRIPE_PLATFORM_FEE_FIXED_CENTS=0
STRIPE_CHECKOUT_BASE_URL=https://klarando.com
STRIPE_PLATFORM_FEE_FIXED_CENTS=0
KLARANDO_PLATFORM_FEE_PERCENT=12
KLARANDO_PLATFORM_FEE_FIXED_CENTS=0

CORS_ORIGINS=https://klarando.com,https://www.klarando.com,https://app.klarando.com,https://admin.klarando.com,https://orderdesk.klarando.com,https://driver.klarando.com
ALLOW_PRODUCTION_DB_PROVISIONING=false
ALLOW_PRODUCTION_DB_DESTRUCTIVE_ACTIONS=false

# Optional: DB-Management / Multi-DB Templates
# DATABASE_ADMIN_URL=postgresql://postgres:replace@postgres:5432/postgres
# CHAIN_DATABASE_TEMPLATE=chain_{chainId}
# TENANT_DATABASE_TEMPLATE=tenant_{tenantId}
# MANUAL_DATABASE_TEMPLATE=tenant_{tenantSlug}
# ENABLE_SEPARATE_CHAIN_DATABASES=false
# ENABLE_SEPARATE_TENANT_DATABASES=false

# Optional: Standard-Auszahlungsdaten (wenn Features aktiv)
# DEFAULT_PAYOUT_ACCOUNT_HOLDER=
# DEFAULT_PAYOUT_IBAN=
# DEFAULT_PAYOUT_BIC=
# DEFAULT_PAYOUT_BANK_NAME=
# DEFAULT_PAYOUT_EMAIL=
# DEFAULT_PAYOUT_REFERENCE=

# -------------------------------------------------
# Web / Next.js Runtime
# -------------------------------------------------
# Wichtig: Bei Compose mit diesem File starten, z. B.
# docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
NEXT_PUBLIC_API_BASE_URL=https://api.klarando.com
# Optional legacy alias (should match NEXT_PUBLIC_API_BASE_URL in production):
# NEXT_PUBLIC_API_URL=https://api.klarando.com
NEXT_PUBLIC_DEFAULT_TENANT_ID=
NEXT_PUBLIC_TENANT_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyAbXD8er0vnHSyzfg3sBI-eYwB7Euov3go
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
