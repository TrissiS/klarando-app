<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <gradient
          android:angle="0"
          android:startColor="#0F172A"
          android:centerColor="#1E293B"
          android:endColor="#0B1220" />
    </shape>
  </item>
  <item android:left="18dp" android:top="18dp" android:right="18dp" android:bottom="18dp">
    <shape android:shape="rectangle">
      <corners android:radius="14dp" />
      <gradient
          android:angle="45"
          android:startColor="#F97316"
          android:endColor="#EC4899" />
    </shape>
  </item>
</layer-list>
